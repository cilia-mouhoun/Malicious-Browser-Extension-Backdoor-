{
  "manifest_version": 3,
  "name": "TypeSmart",
  "version": "1.0.0",
  "description": "Boost your typing productivity with smart auto-correct, shortcuts, and typing analytics.",
  "author": "TypeSmart Team — University Security Module",

  "icons": {
    "48": "assets/icon.png",
    "96": "assets/icon.png"
  },

  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_icon": "assets/icon.png",
    "default_popup": "popup.html",
    "default_title": "TypeSmart — Typing Productivity"
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": [
        "shared/constants.js",
        "shared/schema.js",
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}